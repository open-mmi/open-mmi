[Desktop Entry]
Version=1.0
Type=Application
Name=Open MMI
Comment=Launch the configured Open MMI interface
Exec=/usr/local/bin/open-mmi-launcher
Path=/opt/open-mmi
Icon=open-mmi
Terminal=false
Categories=System;Utility;
StartupNotify=true
Actions=Choose;Web;TUI;

[Desktop Action Choose]
Name=Choose Open MMI Interface
Exec=/usr/local/bin/open-mmi-launcher --choose --remember

[Desktop Action Web]
Name=Use Web Dashboard
Exec=/usr/local/bin/open-mmi-launcher web --remember

[Desktop Action TUI]
Name=Use Terminal UI
Exec=/usr/local/bin/open-mmi-launcher tui --remember
