{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-mmi.org/schema/vehicle-qualification.v1.schema.json",
  "title": "Open MMI maintained vehicle qualification record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_id", "profile_id", "current", "history"],
  "properties": {
    "schema_version": {"const": 1},
    "record_id": {"const": "open-mmi.vehicle-profile-qualification"},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"},
    "current": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "tested_on", "scope", "compatibility", "review"],
      "properties": {
        "level": {"enum": ["none", "replay", "hardware"]},
        "tested_on": {"oneOf": [{"type": "string", "format": "date"}, {"type": "null"}]},
        "scope": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["equipment", "variants"],
          "properties": {
            "equipment": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
            "variants": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reviewers", "reviewed_on", "recheck_after"],
          "properties": {
            "status": {"enum": ["unreviewed", "approved"]},
            "reviewers": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
            "reviewed_on": {"oneOf": [{"type": "string", "format": "date"}, {"type": "null"}]},
            "recheck_after": {"oneOf": [{"type": "string", "format": "date"}, {"type": "null"}]}
          }
        }
      }
    },
    "history": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "date", "reason", "reviewers"],
        "properties": {
          "from": {"enum": ["none", "replay", "hardware"]},
          "to": {"enum": ["none", "replay", "hardware"]},
          "date": {"type": "string", "format": "date"},
          "reason": {"type": "string", "minLength": 1, "maxLength": 512},
          "reviewers": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
        }
      }
    }
  }
}
