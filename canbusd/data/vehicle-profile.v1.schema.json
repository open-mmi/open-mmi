{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-mmi.org/schema/vehicle-profile.v1.schema.json",
  "title": "Open MMI maintained vehicle profile",
  "description": "Identity and evidence envelope for a registry-conformant maintained vehicle profile.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metadata",
    "default_bus",
    "can_buses",
    "rules",
    "presence",
    "status"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "manufacturer",
        "model",
        "generation",
        "platform",
        "model_years",
        "maturity",
        "license",
        "maintainers",
        "qualification"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"},
        "display_name": {"type": "string", "minLength": 1, "maxLength": 128},
        "manufacturer": {"type": "string", "minLength": 1, "maxLength": 128},
        "model": {"type": "string", "minLength": 1, "maxLength": 128},
        "generation": {"type": "string", "minLength": 1, "maxLength": 128},
        "platform": {"type": "string", "minLength": 1, "maxLength": 128},
        "model_years": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": {"type": "integer", "minimum": 1886, "maximum": 2100},
            "to": {"type": "integer", "minimum": 1886, "maximum": 2100}
          }
        },
        "maturity": {
          "enum": ["experimental", "candidate", "qualified", "deprecated"]
        },
        "license": {"const": "GPL-3.0-only"},
        "maintainers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        },
        "limitations": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        },
        "qualification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "last_tested", "scope", "evidence"],
          "properties": {
            "level": {"enum": ["none", "replay", "hardware"]},
            "last_tested": {
              "oneOf": [
                {"type": "string", "format": "date"},
                {"type": "null"}
              ]
            },
            "scope": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1, "maxLength": 256}
            },
            "evidence": {
              "type": "array",
              "maxItems": 64,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "path", "description"],
                "properties": {
                  "kind": {
                    "enum": ["research", "capture", "replay", "hardware", "documentation"]
                  },
                  "path": {"type": "string", "minLength": 1, "maxLength": 240},
                  "description": {"type": "string", "minLength": 1, "maxLength": 512}
                }
              }
            }
          }
        }
      }
    },
    "default_bus": {"type": "string"},
    "can_buses": {"type": "object"},
    "rules": {"type": "array"},
    "presence": {"type": "array"},
    "status": {"type": "array"}
  }
}
