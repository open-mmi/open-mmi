#!/usr/bin/env bash
set -Eeuo pipefail

DESKTOP_FILE="open-mmi-status.desktop"
ICON_NAME="open-mmi"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

SRC_DIR="$REPO_ROOT/packaging/linux-desktop"
DESKTOP_SRC="$SRC_DIR/$DESKTOP_FILE"
ICONS_SRC="$SRC_DIR/icons"

APP_DIR="$HOME/.local/share/applications"
ICON_DIR="$HOME/.local/share/icons"

DESKTOP_DST="$APP_DIR/$DESKTOP_FILE"
HICOLOR_DIR="$ICON_DIR/hicolor"

ICON_SIZES=(
  16x16
  24x24
  32x32
  48x48
  64x64
  128x128
  256x256
  512x512
)

log() {
  printf '[open-mmi-desktop] %s\n' "$*"
}

die() {
  printf '[open-mmi-desktop] ERROR: %s\n' "$*" >&2
  exit 1
}

validate_sources() {
  [[ -f "$DESKTOP_SRC" ]] || die "Missing desktop file: $DESKTOP_SRC"
  [[ -d "$ICONS_SRC/hicolor" ]] || die "Missing hicolor icon directory: $ICONS_SRC/hicolor"

  if command -v desktop-file-validate >/dev/null 2>&1; then
    desktop-file-validate "$DESKTOP_SRC"
  fi
}

install_hicolor_icons() {
  log "Installing Open MMI icons into user hicolor theme"

  for size in "${ICON_SIZES[@]}"; do
    local src="$ICONS_SRC/hicolor/$size/apps/$ICON_NAME.png"
    local dst="$HICOLOR_DIR/$size/apps/$ICON_NAME.png"

    [[ -f "$src" ]] || die "Missing icon: $src"

    mkdir -p "$(dirname "$dst")"
    cp -f "$src" "$dst"
    chmod 0644 "$dst"
  done

  local svg_src="$ICONS_SRC/hicolor/scalable/apps/$ICON_NAME.svg"
  local svg_dst="$HICOLOR_DIR/scalable/apps/$ICON_NAME.svg"

  [[ -f "$svg_src" ]] || die "Missing icon: $svg_src"

  mkdir -p "$(dirname "$svg_dst")"
  cp -f "$svg_src" "$svg_dst"
  chmod 0644 "$svg_dst"
}

remove_hicolor_icons() {
  log "Removing Open MMI hicolor icons"

  for size in "${ICON_SIZES[@]}"; do
    rm -f "$HICOLOR_DIR/$size/apps/$ICON_NAME.png"
  done

  rm -f "$HICOLOR_DIR/scalable/apps/$ICON_NAME.svg"
}

remove_legacy_partial_themes() {
  # Older versions installed these as selectable icon themes.
  # They are incomplete themes and can break panel/app icons if selected
  # or if icon resolution gets confused.
  rm -rf "$ICON_DIR/open-mmi-dark"
  rm -rf "$ICON_DIR/open-mmi-light"
}

remove_legacy_bad_hicolor_index() {
  # Older versions copied packaging/linux-desktop/icons/hicolor/index.theme
  # into ~/.local/share/icons/hicolor/index.theme.
  #
  # Only remove it if it is clearly the Open MMI-generated file.
  local index_file="$HICOLOR_DIR/index.theme"

  [[ -f "$index_file" ]] || return 0

  if grep -q '^Name=open-mmi$' "$index_file" 2>/dev/null; then
    log "Removing legacy Open MMI hicolor index.theme"
    rm -f "$index_file"
  fi
}

refresh_caches() {
  if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database "$APP_DIR" >/dev/null 2>&1 || true
  fi

  # Do not generate/update a user-level hicolor cache unless the user already
  # has a proper hicolor index.theme. The icons work without forcing a cache,
  # and avoiding this prevents the Cinnamon/Mint icon-theme issue we hit.
  if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    if [[ -f "$HICOLOR_DIR/index.theme" ]]; then
      gtk-update-icon-cache -q -t -f "$HICOLOR_DIR" >/dev/null 2>&1 || true
    fi
  fi
}

install_desktop() {
  validate_sources

  log "Installing desktop launcher"

  mkdir -p "$APP_DIR"
  cp -f "$DESKTOP_SRC" "$DESKTOP_DST"
  chmod 0644 "$DESKTOP_DST"

  mkdir -p "$ICON_DIR"

  remove_legacy_partial_themes
  remove_legacy_bad_hicolor_index
  install_hicolor_icons
  refresh_caches

  log "Installed launcher: $DESKTOP_DST"
  log "Installed icon files under: $HICOLOR_DIR"
}

remove_desktop() {
  log "Removing desktop launcher"

  rm -f "$DESKTOP_DST"

  remove_hicolor_icons
  remove_legacy_partial_themes
  remove_legacy_bad_hicolor_index
  refresh_caches

  log "Removed desktop launcher and Open MMI icons"
}

case "${1:-}" in
  install)
    install_desktop
    ;;
  remove|uninstall)
    remove_desktop
    ;;
  reinstall)
    remove_desktop
    install_desktop
    ;;
  *)
    echo "Usage: $0 install|remove|reinstall"
    exit 1
    ;;
esac