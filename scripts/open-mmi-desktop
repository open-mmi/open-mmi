#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ASSET_ROOT="$REPO_ROOT/packaging/linux-desktop"
DESKTOP_SOURCES=(
    "$ASSET_ROOT/open-mmi-status.desktop"
    "$ASSET_ROOT/open-mmi-chooser.desktop"
)
ICON_SOURCE="$ASSET_ROOT/icons"
DATA_HOME="${XDG_DATA_HOME:-${HOME:?HOME is not set}/.local/share}"
APPLICATION_DIR="$DATA_HOME/applications"
ICON_DESTINATION="$DATA_HOME/icons"

usage() {
    cat <<USAGE
Usage: $0 {install|remove|reinstall}

Installs or removes the Open MMI launcher and interface-recovery application
entries for the current user. XDG_DATA_HOME is honoured when set.
USAGE
}

require_assets() {
    local desktop_source
    for desktop_source in "${DESKTOP_SOURCES[@]}"; do
        if [[ ! -f "$desktop_source" ]]; then
            echo "[desktop] ERROR: missing desktop entry: $desktop_source" >&2
            return 1
        fi
    done
    if [[ ! -d "$ICON_SOURCE" ]]; then
        echo "[desktop] ERROR: missing icon directory: $ICON_SOURCE" >&2
        return 1
    fi
}

refresh_caches() {
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database "$APPLICATION_DIR" >/dev/null 2>&1 || true
    fi

    if command -v gtk-update-icon-cache >/dev/null 2>&1 \
        && [[ -d "$ICON_DESTINATION/hicolor" ]]; then
        gtk-update-icon-cache -f -t "$ICON_DESTINATION/hicolor" >/dev/null 2>&1 || true
    fi
}

install_launcher() {
    local desktop_source desktop_destination
    require_assets

    mkdir -p "$APPLICATION_DIR" "$ICON_DESTINATION"
    for desktop_source in "${DESKTOP_SOURCES[@]}"; do
        desktop_destination="$APPLICATION_DIR/$(basename "$desktop_source")"
        install -m 0644 "$desktop_source" "$desktop_destination"
        if command -v desktop-file-validate >/dev/null 2>&1; then
            desktop-file-validate "$desktop_destination"
        fi
    done
    cp -a "$ICON_SOURCE/." "$ICON_DESTINATION/"

    refresh_caches
    echo "[desktop] Installed Open MMI launchers in $APPLICATION_DIR"
}

remove_launcher() {
    local desktop_source
    for desktop_source in "${DESKTOP_SOURCES[@]}"; do
        rm -f "$APPLICATION_DIR/$(basename "$desktop_source")"
    done

    if [[ -d "$ICON_SOURCE" ]]; then
        while IFS= read -r -d '' source_icon; do
            relative_path="${source_icon#"$ICON_SOURCE"/}"
            rm -f "$ICON_DESTINATION/$relative_path"
        done < <(find "$ICON_SOURCE" -type f -print0)
    fi

    refresh_caches
    echo "[desktop] Removed the Open MMI desktop launcher"
}

case "${1:-}" in
    install)
        install_launcher
        ;;
    remove)
        remove_launcher
        ;;
    reinstall)
        remove_launcher
        install_launcher
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
