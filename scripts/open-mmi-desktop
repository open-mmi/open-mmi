#!/usr/bin/env bash
set -Eeuo pipefail

APP_ID="open-mmi-status"
DESKTOP_FILE="open-mmi-status.desktop"
ICON_NAME="open-mmi"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

PKG_DIR="$REPO_ROOT/packaging/linux-desktop"
DESKTOP_SRC="$PKG_DIR/$DESKTOP_FILE"
ICONS_SRC="$PKG_DIR/icons"

TARGET_USER="${SUDO_USER:-${USER:-$(id -un)}}"
TARGET_HOME="$(getent passwd "$TARGET_USER" | cut -d: -f6)"

APPLICATIONS_DIR="$TARGET_HOME/.local/share/applications"
ICONS_DIR="$TARGET_HOME/.local/share/icons"

THEMES=(
  "hicolor"
  "open-mmi-dark"
  "open-mmi-light"
)

ICON_FILES=(
  "16x16/apps/open-mmi.png"
  "24x24/apps/open-mmi.png"
  "32x32/apps/open-mmi.png"
  "48x48/apps/open-mmi.png"
  "64x64/apps/open-mmi.png"
  "128x128/apps/open-mmi.png"
  "256x256/apps/open-mmi.png"
  "512x512/apps/open-mmi.png"
  "scalable/apps/open-mmi.svg"
)

log() {
  printf '[open-mmi-desktop] %s\n' "$*"
}

die() {
  printf '[open-mmi-desktop] ERROR: %s\n' "$*" >&2
  exit 1
}

as_target_user() {
  if [[ "$(id -u)" -eq 0 && "$TARGET_USER" != "root" ]]; then
    sudo -u "$TARGET_USER" env HOME="$TARGET_HOME" "$@"
  else
    "$@"
  fi
}

need_sources() {
  [[ -f "$DESKTOP_SRC" ]] || die "Missing desktop file: $DESKTOP_SRC"
  [[ -d "$ICONS_SRC" ]] || die "Missing icons directory: $ICONS_SRC"

  for theme in "${THEMES[@]}"; do
    [[ -d "$ICONS_SRC/$theme" ]] || die "Missing icon theme: $ICONS_SRC/$theme"
  done
}

copy_theme() {
  local theme="$1"
  local src="$ICONS_SRC/$theme"
  local dst="$ICONS_DIR/$theme"

  log "Installing icon theme: $theme"

  mkdir -p "$dst"

  while IFS= read -r -d '' dir; do
    mkdir -p "$dst/$dir"
  done < <(cd "$src" && find . -type d -print0)

  while IFS= read -r -d '' file; do
    # Avoid overwriting an existing user hicolor index.theme.
    # hicolor is a shared fallback theme, unlike open-mmi-dark/light.
    if [[ "$theme" == "hicolor" && "$file" == "./index.theme" && -e "$dst/index.theme" ]]; then
      continue
    fi

    mkdir -p "$dst/$(dirname "$file")"
    cp -f "$src/$file" "$dst/$file"
  done < <(cd "$src" && find . -type f -print0)
}

fix_ownership() {
  [[ "$(id -u)" -eq 0 ]] || return 0

  local target_group
  target_group="$(id -gn "$TARGET_USER")"

  chown "$TARGET_USER:$target_group" "$APPLICATIONS_DIR/$DESKTOP_FILE" 2>/dev/null || true

  for theme in "${THEMES[@]}"; do
    [[ -d "$ICONS_DIR/$theme" ]] || continue
    chown -R "$TARGET_USER:$target_group" "$ICONS_DIR/$theme" 2>/dev/null || true
  done
}

refresh_desktop_database() {
  if command -v update-desktop-database >/dev/null 2>&1; then
    as_target_user update-desktop-database "$APPLICATIONS_DIR" >/dev/null 2>&1 || true
  fi
}

refresh_icon_cache() {
  command -v gtk-update-icon-cache >/dev/null 2>&1 || return 0

  for theme in "${THEMES[@]}"; do
    local theme_dir="$ICONS_DIR/$theme"

    [[ -d "$theme_dir" ]] || continue
    [[ -f "$theme_dir/index.theme" ]] || continue

    as_target_user gtk-update-icon-cache -q -t -f "$theme_dir" >/dev/null 2>&1 || true
  done
}

validate_desktop_file() {
  command -v desktop-file-validate >/dev/null 2>&1 || return 0

  if ! desktop-file-validate "$DESKTOP_SRC"; then
    die "Desktop file failed validation: $DESKTOP_SRC"
  fi
}

install_desktop() {
  need_sources
  validate_desktop_file

  log "Installing desktop launcher for user: $TARGET_USER"

  mkdir -p "$APPLICATIONS_DIR"
  cp -f "$DESKTOP_SRC" "$APPLICATIONS_DIR/$DESKTOP_FILE"
  chmod 0644 "$APPLICATIONS_DIR/$DESKTOP_FILE"

  for theme in "${THEMES[@]}"; do
    copy_theme "$theme"
  done

  fix_ownership
  refresh_desktop_database
  refresh_icon_cache

  log "Installed launcher: $APPLICATIONS_DIR/$DESKTOP_FILE"
  log "Installed icons under: $ICONS_DIR"
}

remove_hicolor_icons() {
  local dst="$ICONS_DIR/hicolor"

  [[ -d "$dst" ]] || return 0

  for rel in "${ICON_FILES[@]}"; do
    rm -f "$dst/$rel"
  done
}

remove_custom_theme() {
  local theme="$1"
  local dst="$ICONS_DIR/$theme"

  [[ -d "$dst" ]] || return 0

  rm -rf "$dst"
}

remove_desktop() {
  log "Removing desktop launcher for user: $TARGET_USER"

  rm -f "$APPLICATIONS_DIR/$DESKTOP_FILE"

  # hicolor is shared by all apps, so only remove Open MMI icon files.
  remove_hicolor_icons

  # These themes are Open MMI-specific, so they can be removed entirely.
  remove_custom_theme "open-mmi-dark"
  remove_custom_theme "open-mmi-light"

  refresh_desktop_database
  refresh_icon_cache

  log "Removed launcher: $APPLICATIONS_DIR/$DESKTOP_FILE"
  log "Removed Open MMI icon files"
}

show_status() {
  printf 'Desktop file: %s\n' "$APPLICATIONS_DIR/$DESKTOP_FILE"

  if [[ -f "$APPLICATIONS_DIR/$DESKTOP_FILE" ]]; then
    printf 'Launcher: installed\n'
  else
    printf 'Launcher: not installed\n'
  fi

  for theme in "${THEMES[@]}"; do
    if [[ -d "$ICONS_DIR/$theme" ]]; then
      printf 'Icon theme %-15s installed at %s\n' "$theme:" "$ICONS_DIR/$theme"
    else
      printf 'Icon theme %-15s not installed\n' "$theme:"
    fi
  done
}

usage() {
  cat <<EOF
Usage:
  $0 install
  $0 remove
  $0 reinstall
  $0 status

Installs/removes the optional Open MMI desktop launcher and icon themes.

This is per-user by default:
  launcher -> ~/.local/share/applications/$DESKTOP_FILE
  icons    -> ~/.local/share/icons/

When run with sudo, it installs for the original sudo user, not root.
EOF
}

main() {
  case "${1:-}" in
    install)
      install_desktop
      ;;
    remove|uninstall)
      remove_desktop
      ;;
    reinstall)
      remove_desktop
      install_desktop
      ;;
    status)
      show_status
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      usage
      die "Unknown command: $1"
      ;;
  esac
}

main "$@"
